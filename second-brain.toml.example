[database]
url = "postgresql://secondbrain:secondbrain@localhost:5432/secondbrain"

[notes]
paths = ["~/notes"]  # Directories to watch for markdown notes

[embedding]
# Use a preset for quick configuration. All presets use Ollama:
#   nomic      — nomic-embed-text (768d, fast on CPU, default)
#   all-minilm — all-minilm (384d, smallest/fastest)
#   snowflake  — snowflake-arctic-embed2 (768d, good balance)
#   mxbai      — mxbai-embed-large (1024d, high quality)
#   qwen3      — qwen3-embedding (1024d, best quality, slow on CPU)
preset = "nomic"

# Individual fields override the preset:
# url = "http://localhost:11434"   # Ollama server URL
# model = "nomic-embed-text"       # Model name
# dimensions = 768                 # Vector dimensions
# batch_size = 32                  # Texts per batch request
# max_chunk_chars = 2400           # Max characters per chunk

# Example: higher quality model
# [embedding]
# preset = "qwen3"

# Optional: LLM for autonomous skill execution (not needed for interactive use)
# [llm]
# provider = "anthropic"
# model = "claude-sonnet-4-20250514"
# api_key = "sk-..."   # or set ANTHROPIC_API_KEY env var

# Project directories to observe (symlinked into the KB)
# [[projects]]
# name = "example_project"
# path = "~/example_project"
# branch = "main"
# patterns = ["docs/**/*.md", "README.md", "**/README.md"]
# mirror_to = "projects/example_project"
