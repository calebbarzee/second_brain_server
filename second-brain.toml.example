[database]
url = "postgresql://secondbrain:secondbrain@localhost:5432/secondbrain"

[notes]
paths = ["~/notes"]  # Directories to watch for markdown notes

[embedding]
# Use a preset for quick configuration. Available presets:
#   nomic        — nomic-embed-text via Ollama (768d, fast on CPU)
#   nomic-moe    — nomic-embed-text-moe via Ollama (768d)
#   all-minilm   — all-minilm via Ollama (384d, smallest)
#   snowflake    — snowflake-arctic-embed2 via Ollama (1024d)
#   mxbai        — mxbai-embed-large via Ollama (1024d)
#   qwen3        — qwen3-embedding via Ollama (1024d, best quality local)
#   openai-small — text-embedding-3-small via OpenAI (1536d)
#   openai-large — text-embedding-3-large via OpenAI (3072d)
#   tei          — BAAI/bge-base-en-v1.5 via Docker TEI (768d)
preset = "nomic"

# Individual fields override the preset:
# provider = "openai"              # "tei" or "openai" (Ollama uses openai protocol)
# url = "http://localhost:11434"   # Embedding server URL
# model = "nomic-embed-text"       # Model name
# dimensions = 768                 # Vector dimensions
# batch_size = 32                  # Texts per batch request
# max_chunk_chars = 2400           # Max characters per chunk

# Example: Ollama with qwen3-embedding (higher quality, larger model)
# [embedding]
# preset = "qwen3"

# Example: OpenAI cloud
# [embedding]
# preset = "openai-small"
# Or manually:
# provider = "openai"
# url = "https://api.openai.com"
# model = "text-embedding-3-small"
# dimensions = 1536

# Example: TEI via Docker (docker compose up -d)
# [embedding]
# preset = "tei"

# Optional: LLM for autonomous skill execution (not needed for interactive use)
# [llm]
# provider = "anthropic"
# model = "claude-sonnet-4-20250514"
# api_key = "sk-..."   # or set ANTHROPIC_API_KEY env var

# Project directories to observe (symlinked into the KB)
# [[projects]]
# name = "example_project"
# path = "~/example_project"
# branch = "main"
# patterns = ["docs/**/*.md", "README.md", "**/README.md"]
# mirror_to = "projects/example_project"
